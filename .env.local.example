# Salin file ini menjadi .env.local lalu isi nilainya.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opsional untuk MVP (belum dipakai route mana pun)
SUPABASE_SERVICE_ROLE_KEY=

# ── Provider AI untuk halaman Rekomendasi (opsional) ──
# Isi SALAH SATU. Kalau semua kosong, otomatis pakai narasi template offline
# (gratis, tetap jalan untuk demo). Prioritas bila diisi: Gemini > OpenAI > Claude.

# Google Gemini (free tier) — aistudio.google.com/apikey
GEMINI_API_KEY=
# opsional, default gemini-2.5-flash
GEMINI_MODEL=

# OpenAI — platform.openai.com/api-keys
OPENAI_API_KEY=
# opsional, default gpt-4o-mini
OPENAI_MODEL=

# Anthropic Claude — console.anthropic.com
ANTHROPIC_API_KEY=
# opsional, default claude-sonnet-5
ANTHROPIC_MODEL=
